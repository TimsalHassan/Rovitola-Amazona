# ============================================
# Django Settings
# ============================================

# Secret key for Django - generate a new one in production
# You can generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here-change-in-production

# Debug mode - set to False in production
DEBUG=True

# Allowed hosts for your application (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# Database Configuration (PostgreSQL)
# ============================================

# Database name
DB_NAME=rovintola

# Database user
DB_USER=postgres

# Database password
DB_PASSWORD=postgres

# Database host
DB_HOST=localhost

# Database port
DB_PORT=5432

# ============================================
# Redis Configuration (for Celery & Caching)
# ============================================

# Redis URL for caching and Celery task broker
REDIS_URL=redis://127.0.0.1:6379/1

# ============================================
# URLs
# ============================================

# Frontend URL - used for CORS and redirects
